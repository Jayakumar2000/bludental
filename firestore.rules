// neudental v1 - Firestore Security Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.patientName is string
        && request.resource.data.patientName.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.treatmentId is string
        && request.resource.data.date is string
        && request.resource.data.timeSlot is string
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      allow delete: if false;
    }
  }
}
